{
  "ConnectionStrings": {
    "DefaultConnection": "server=localhost;port=3306;database=flexirent;user=root;password=YourStrongPassword;"
  },
  "JwtSettings": {
    "Secret": "ChangeThisSecretToAStrongOne",
    "Issuer": "FlexiRent",
    "Audience": "FlexiRentClients",
    "AccessTokenExpiryMinutes": "60",
    "RefreshTokenExpiryDays": "30"
  },
  "FileStorage": {
    "BasePath": "uploads"
  },
  "SendGrid": {
    "ApiKey": "YOUR_SENDGRID_API_KEY",
    "FromEmail": "no-reply@flexirent.example",
    "FromName": "FlexiRent"
  },
  "EnableSwagger": true,
  "Logging": {
    "LogLevel": {
      "Default": "Information"
    }
  }
}
