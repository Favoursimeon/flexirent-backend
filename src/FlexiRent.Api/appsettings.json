{
    "ConnectionStrings": {
        "DefaultConnection": "Host=localhost;Port=5432;Database=FlexiRent;Username=postgres;Password=postgres;"
    },
    "AllowedOrigins": [
        "http://localhost:3000",
        "http://localhost:5173",
        "https://flexirent.com"
    ],
    "JwtSettings": {
        "Secret": "ChangeThisToAStrongSecretThatIsAtLeast32Chars!",
        "Issuer": "FlexiRent",
        "Audience": "FlexiRentClients",
        "AccessTokenExpiryMinutes": "15",
        "RefreshTokenExpiryDays": "7"
    },
    "FileStorage": {
        "BasePath": "uploads"
    },

    "Redis": {
        "ConnectionString": "localhost:6379"
    },

    "Paystack": {
        "SecretKey": "sk_test_your_paystack_secret_key",
        "PublicKey": "pk_test_your_paystack_public_key",
        "BaseUrl": "https://api.paystack.co",
        "WebhookSecret": "your_webhook_secret"
    },

    "Hangfire": {
        "Dashboard": true
    },

    "IpRateLimiting": {
        "EnableEndpointRateLimiting": true,
        "StackBlockedRequests": false,
        "RealIpHeader": "X-Real-IP",
        "ClientIdHeader": "X-ClientId",
        "HttpStatusCode": 429,
        "GeneralRules": [
            {
                "Endpoint": "*",
                "Period": "1m",
                "Limit": 100
            },
            {
                "Endpoint": "POST:/api/auth/login",
                "Period": "5m",
                "Limit": 10
            },
            {
                "Endpoint": "POST:/api/auth/register",
                "Period": "1h",
                "Limit": 5
            },
            {
                "Endpoint": "POST:/api/auth/forgot-password",
                "Period": "1h",
                "Limit": 5
            }
        ]
    },

    "SendGrid": {
        "ApiKey": "YOUR_SENDGRID_API_KEY",
        "FromEmail": "no-reply@flexirent.example",
        "FromName": "FlexiRent"
    },
    "EnableSwagger": true,
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning",
            "Microsoft.EntityFrameworkCore.Database.Command": "Information"
        }
    },
    "AllowedHosts": "*"
}