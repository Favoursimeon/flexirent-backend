{
    "ConnectionStrings": {
        "DefaultConnection": "Host=localhost;Port=5432;Database=FlexiRent;Username=postgres;Password=postgres;"
    },
    "AllowedOrigins": [
        "http://localhost:3000",
        "http://localhost:5173"
    ],
    "JwtSettings": {
        "Secret": "ChangeThisToAStrongSecretThatIsAtLeast32Chars!",
        "Issuer": "FlexiRent",
        "Audience": "FlexiRentClients",
        "AccessTokenExpiryMinutes": "60",
        "RefreshTokenExpiryDays": "30"
    },
    "FileStorage": {
        "BasePath": "uploads"
    },
    "SendGrid": {
        "ApiKey": "YOUR_SENDGRID_API_KEY",
        "FromEmail": "no-reply@flexirent.example",
        "FromName": "FlexiRent"
    },
    "EnableSwagger": true,
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning",
            "Microsoft.EntityFrameworkCore.Database.Command": "Information"
        }
    },
    "AllowedHosts": "*"
}